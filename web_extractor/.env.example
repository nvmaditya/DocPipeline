# LLM Configuration (optional)
# Set to true to enable LLM-based query rewriting
USE_LLM_REWRITER=true
# Set to true to enable LLM-based content structuring
USE_LLM_STRUCTURER=true

# LLM API Configuration
# LLM_API_KEY=AIzaSyDIP9Q6zT7WCwKfLLdptlprnxK7Aa4belo
# LLM_MODEL=gemini-2.5-flash

# Search Settings
MAX_RESULTS=10
MAX_RETRIES=3
TIMEOUT=10

# Cache Settings
CACHE_DIR=./cache
CACHE_ENABLED=true
CACHE_TTL=3600

# Logging
DEBUG=false
